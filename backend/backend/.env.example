NODE_ENV=development
PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017/stock-register
REDIS_URL=redis://127.0.0.1:6379
JWT_ACCESS_SECRET=replace-with-a-long-access-secret
JWT_REFRESH_SECRET=replace-with-a-long-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=30
APP_URL=http://localhost:5173
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=Stock Register <no-reply@example.com>
REPORT_OUTPUT_DIR=reports
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PRO_PLAN_ID=
RAZORPAY_ENTERPRISE_PLAN_ID=
RAZORPAY_PRO_AMOUNT=99900
RAZORPAY_ENTERPRISE_AMOUNT=499900
RAZORPAY_BILLING_CYCLES=12
