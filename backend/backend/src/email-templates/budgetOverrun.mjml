<mjml>
  <mj-body background-color="#fef2f2">
    <mj-section background-color="#ffffff" padding="32px">
      <mj-column>
        <mj-text font-size="22px" font-weight="bold" color="#b91c1c">Budget alert</mj-text>
        <mj-text>{{departmentName}} has used or committed {{utilization}}% of its budget. Allocated budget: {{allocated}}.</mj-text>
      </mj-column>
    </mj-section>
  </mj-body>
</mjml>
