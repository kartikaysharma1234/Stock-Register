<mjml>
  <mj-body background-color="#fff7ed">
    <mj-section background-color="#ffffff" padding="32px">
      <mj-column>
        <mj-text font-size="22px" font-weight="bold" color="#c2410c">Batch expiry alert</mj-text>
        <mj-text>{{itemName}} batch {{batchNumber}} expires on {{expiryDate}}. Remaining quantity: {{quantity}}.</mj-text>
      </mj-column>
    </mj-section>
  </mj-body>
</mjml>
