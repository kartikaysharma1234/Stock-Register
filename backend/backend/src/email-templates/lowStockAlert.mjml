<mjml>
  <mj-body background-color="#fff7ed">
    <mj-section background-color="#ffffff" padding="32px">
      <mj-column>
        <mj-text font-size="22px" font-weight="bold" color="#c2410c">Low stock alert</mj-text>
        <mj-text>{{itemName}} ({{sku}}) has {{quantity}} units remaining. The threshold is {{threshold}}.</mj-text>
      </mj-column>
    </mj-section>
  </mj-body>
</mjml>
