<mjml>
  <mj-body background-color="#f5f7fb">
    <mj-section background-color="#ffffff" padding="32px">
      <mj-column>
        <mj-text font-size="22px" font-weight="bold">Reset your password</mj-text>
        <mj-text>Hello {{name}}, use the button below to choose a new password. This link expires in one hour.</mj-text>
        <mj-button background-color="#2563eb" href="{{resetUrl}}">Reset password</mj-button>
      </mj-column>
    </mj-section>
  </mj-body>
</mjml>
