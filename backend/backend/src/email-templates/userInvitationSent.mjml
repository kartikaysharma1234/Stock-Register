<mjml>
  <mj-body background-color="#f5f7fb">
    <mj-section background-color="#ffffff" padding="32px">
      <mj-column>
        <mj-text font-size="22px" font-weight="bold">Invitation sent</mj-text>
        <mj-text>{{name}} has been invited to Stock Register.</mj-text>
        <mj-text><strong>Email:</strong> {{email}}<br/><strong>Role:</strong> {{role}}</mj-text>
      </mj-column>
    </mj-section>
  </mj-body>
</mjml>
