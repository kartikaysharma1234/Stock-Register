<mjml>
  <mj-body background-color="#f5f7fb">
    <mj-section background-color="#ffffff" padding="32px">
      <mj-column>
        <mj-text font-size="22px" font-weight="bold">Stock request approval required</mj-text>
        <mj-text>Request {{requestNumber}} is awaiting your approval.</mj-text>
        <mj-text>Current status: <strong>{{status}}</strong></mj-text>
      </mj-column>
    </mj-section>
  </mj-body>
</mjml>
